# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amboras_analytics?schema=public"

# JWT signing secret for auth tokens
JWT_SECRET="dev-secret-change-in-production"

# Optional runtime settings
PORT=3001
CORS_ORIGINS="http://localhost:3000"

# Optional seed tuning
SEED_TOTAL_EVENTS=100000
SEED_BATCH_SIZE=500
